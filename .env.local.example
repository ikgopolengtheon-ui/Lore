# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and never committed.

# Anthropic API key — required for the grounded LLM route (/api/chat) and image
# OCR (/api/extract). Get one at https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram API key — speech-to-text (/api/stt). https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ElevenLabs API key — text-to-speech (/api/tts). https://elevenlabs.io/app
ELEVENLABS_API_KEY=

# Optional overrides:
# LORE_LLM_MODEL=claude-sonnet-5          # claude-opus-4-8 for max capability
# LORE_TTS_VOICE_ID=SAz9YHcvj6GT2YYXdXww  # ElevenLabs voice id (default: "River")
# LORE_TTS_MODEL=eleven_turbo_v2_5         # ElevenLabs TTS model
