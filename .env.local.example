# Copy this file to .env.local and fill in your key.
# .env.local is gitignored and never committed.

# Anthropic API key — required for the grounded LLM route (/api/chat).
# Get one at https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the LLM model. Defaults to claude-sonnet-5.
# Use claude-opus-4-8 for maximum capability (higher cost).
# LORE_LLM_MODEL=claude-sonnet-5
